    {
      "name": "Public",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"]
            },
            "description": "Root endpoint"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Health check endpoint"
          }
        },
        {
          "name": "Home Data",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/home",
              "host": ["{{baseUrl}}"],
              "path": ["api", "home"]
            },
            "description": "Get all homepage data (banners, featured products, flash sales, etc.)"
          }
        },
        {
          "name": "Products List",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?category=ao-nam&brand=gucci&gender=nam&min_price=100000&max_price=500000&sort=price&order=asc&page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {"key": "category", "value": "ao-nam", "description": "Filter by category slug"},
                {"key": "brand", "value": "gucci", "description": "Filter by brand slug"},
                {"key": "gender", "value": "nam", "description": "Filter by gender (nam/nu/unisex)"},
                {"key": "age_group", "value": "adult", "description": "Filter by age group (adult/kids)"},
                {"key": "min_price", "value": "100000", "description": "Min price filter"},
                {"key": "max_price", "value": "500000", "description": "Max price filter"},
                {"key": "sort", "value": "created_at", "description": "Sort by (created_at/price/name/total_sold/view_count)"},
                {"key": "order", "value": "desc", "description": "Sort order (asc/desc)"},
                {"key": "page", "value": "1", "description": "Page number"},
                {"key": "limit", "value": "12", "description": "Items per page"}
              ]
            },
            "description": "Get products with filters"
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/search?q=ao",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "search"],
              "query": [
                {"key": "q", "value": "ao", "description": "Search query (min 2 characters)", "disabled": false}
              ]
            },
            "description": "Search products by name, description, or brand"
          }
        },
        {
          "name": "Kids Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/kids-categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "kids-categories"]
            },
            "description": "Get kids product categories with counts"
          }
        },
        {
          "name": "Product Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/ao-thun-nam-cao-cap",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{slug}}"]
            },
            "description": "Get product detail by slug. Replace {{slug}} with actual product slug"
          }
        },
        {
          "name": "News List",
          "request": {
            "method": "GET",
